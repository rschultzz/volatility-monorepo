# Application database — SQLAlchemy engine form (postgresql+psycopg:// prefix required)
DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>/<db>?sslmode=require

# Backfill database — dash_backfill_writer role (SELECT + INSERT only; no DELETE/TRUNCATE/DROP)
# Plain postgresql:// form for psql/script compatibility (no SQLAlchemy driver prefix)
# Used exclusively by unattended CR backfill scripts via packages/shared/backfill_safety.py
BACKFILL_DATABASE_URL=postgresql://dash_backfill_writer:<password>@<host>/<db>?sslmode=require

ORATS_TOKEN=<your-orats-api-token>
APP_ENV=local
LOG_LEVEL=INFO
